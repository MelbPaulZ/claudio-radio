# ========================================
# Claudio Radio —— 环境变量配置
# 使用方法：
#   cp .env.example .env
# 然后把下面标了 [必填] 的项填上你的值
# ========================================

# ---------- 网易云音乐 ----------
# [必填] 你的网易云用户 ID
# 怎么拿：网易云 APP "我的" → 右上角头像 → 分享 → 复制链接，URL 里 userId= 后的那串数字
NETEASE_USER_ID=

# 本地 NeteaseCloudMusicApi 的地址（默认即可，`npm run ncm` 会起起来）
# 默认端口 3335（避开常用的 3000）。要改端口的话，NETEASE_API_URL 和 NCM_PORT 要同步改
NETEASE_API_URL=http://localhost:3335
# 可选：NCM 代理服务跑的端口，默认 3335
# NCM_PORT=3335

# [必填] 网易云登录 cookie —— 没这个只能拿到试听 30 秒版 / 非版权歌
# 怎么拿：浏览器打开 music.163.com 并登录 → F12 → Application → Cookies → music.163.com → 找到 MUSIC_U 复制它的 value
# 格式必须带 MUSIC_U= 前缀，例如：NETEASE_COOKIE=MUSIC_U=0006771470CEA2F7...（很长一串）
NETEASE_COOKIE=MUSIC_U=

# ---------- LLM 大脑 ----------
# 选择哪个 LLM provider：
#   claude-cli  默认。本机起 Claude Code CLI 子进程，用 Max 订阅。需要本机装好 claude
#   claude-api  Anthropic HTTP API。需要 ANTHROPIC_API_KEY（仅在能访问 Anthropic 的网络下用）
#   doubao      字节豆包（火山引擎 Ark）。中国大陆部署推荐。需要 DOUBAO_API_KEY
LLM_PROVIDER=claude-cli

# 仅当 LLM_PROVIDER=claude-api 时才填
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6

# 仅当 LLM_PROVIDER=doubao 时才填
# 申请 API key：https://console.volcengine.com/ark
DOUBAO_API_KEY=
DOUBAO_MODEL=doubao-pro-32k
# DOUBAO_ENDPOINT=https://ark.cn-beijing.volces.com/api/v3/chat/completions  # 默认值，一般不用改

# ⚠️ 旧字段 CLAUDE_MODE 已废弃（v0.2.0 起）。如果你有旧 .env，按下面映射改：
#   CLAUDE_MODE=cli → LLM_PROVIDER=claude-cli
#   CLAUDE_MODE=api → LLM_PROVIDER=claude-api

# ---------- TTS（文字转语音，火山引擎豆包大模型）----------
# 目前只支持 volc，留着这个字段为未来扩展
TTS_PROVIDER=volc

# [必填] 火山引擎凭证
# 怎么拿：https://console.volcengine.com/speech/ → 实名认证 → 开通"语音合成大模型"
#        → 应用管理 → 创建应用 → 里面能拿到 AppID 和 Access Token
VOLC_APPID=
VOLC_ACCESS_TOKEN=

# 豆包大模型固定值，不用改
VOLC_CLUSTER=volcano_tts

# 音色 ID（在火山控制台"音色管理"里查）
# 推荐几个适合电台 DJ 的：
#   zh_female_vv_uranus_bigtts            VV（默认，活泼清亮，适合日间档）
#   zh_female_wanwanxiaohe_moon_bigtts    湾湾小何（夜间 / 深夜）
#   zh_male_jingqiangkanye_moon_bigtts    京腔侃爷（深夜松弛感）
#   zh_female_qingxinnvsheng_moon_bigtts  清新女声（中午 / 下午）
VOLC_VOICE=zh_female_vv_uranus_bigtts

# 合成音量倍率，默认 1.5，范围 0.1–3.0；DJ 嫌小就调大，嫌吵就调小。
# 改了之后旧缓存（cache/tts/*.mp3）会自动失效，下次合成才生效。
VOLC_VOLUME_RATIO=1.5

# ---------- 天气（OpenWeather）----------
# [必填] OpenWeather API key —— https://openweathermap.org/api 免费注册
OPENWEATHER_API_KEY=

# 你所在城市（英文或中文都行，也支持 "lat,lon" 格式）
WEATHER_CITY=Shanghai

# ---------- 服务器 ----------
PORT=8787

# 日志级别: debug | info | warn
LOG_LEVEL=info

# ---------- 日历（可选）----------
# 跨平台日历来源：填一个 ICS 订阅链接，DJ 会把今天的日程穿插进串词。
# Google Calendar / iCloud Calendar / Outlook 都支持导出 ICS 订阅链接。
# 留空：macOS 用户走 icalBuddy/AppleScript（仅裸跑）；其他平台/Docker 部署 → 日历功能关闭。
# CALENDAR_ICS_URL=https://calendar.google.com/calendar/ical/.../basic.ics

# ---------- Docker 部署（可选）----------
# 锁定 Docker 镜像版本（默认 latest）。
# 例如 v0.1.0、v0.2.0；遇到坏版本可以回滚指定旧 tag。
# CLAUDIO_VERSION=latest

# 容器内 SQLite 数据库路径（默认 /app/data/state.db，由 compose.yml 设定）。
# 裸跑模式下不要设置这个变量，会用默认的 <repo>/state.db。
# STATE_DB_PATH=/app/data/state.db
